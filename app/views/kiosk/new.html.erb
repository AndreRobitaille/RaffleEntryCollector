<div class="screen-form">
  <div class="screen-form__header">
    <%= image_tag "FF-Sec_RGB_Logo_darkmode.png", alt: "Final Frontier Security", class: "screen-form__logo" %>
    <h1 class="screen-form__title">Raffle Entry</h1>
  </div>

  <%= form_with(model: @entrant, url: enter_path, html: { class: "screen-form__content" }) do |f| %>
    <div class="screen-form__body">
      <div class="eligibility-gate <%= 'eligibility-gate--error' if @entrant.errors[:eligibility_confirmed].any? %>">
        <div>
          <%= f.check_box :eligibility_confirmed, id: "eligibility_confirmed" %>
        </div>
        <div>
          <%= f.label :eligibility_confirmed, "I confirm that I am not employed by CypherCon or a CypherCon sponsor and am eligible under the raffle rules." %>
          <% if @entrant.errors[:eligibility_confirmed].any? %>
            <div class="eligibility-gate__error"><%= @entrant.errors[:eligibility_confirmed].first %></div>
          <% end %>
        </div>
      </div>

      <div class="form-grid">
        <div class="form-field <%= 'form-field--error' if @entrant.errors[:first_name].any? %>">
          <%= f.label :first_name %>
          <%= f.text_field :first_name, autocomplete: "nope" %>
          <% if @entrant.errors[:first_name].any? %>
            <span class="form-field__error"><%= @entrant.errors[:first_name].first %></span>
          <% end %>
        </div>

        <div class="form-field <%= 'form-field--error' if @entrant.errors[:last_name].any? %>">
          <%= f.label :last_name %>
          <%= f.text_field :last_name, autocomplete: "nope" %>
          <% if @entrant.errors[:last_name].any? %>
            <span class="form-field__error"><%= @entrant.errors[:last_name].first %></span>
          <% end %>
        </div>

        <div class="form-field <%= 'form-field--error' if @entrant.errors[:email].any? %>">
          <%= f.label :email, "Work Email" %>
          <%= f.email_field :email, autocomplete: "nope" %>
          <% if @entrant.errors[:email].any? %>
            <span class="form-field__error"><%= @entrant.errors[:email].first %></span>
          <% end %>
        </div>

        <div class="form-field <%= 'form-field--error' if @entrant.errors[:company].any? %>">
          <%= f.label :company, "Company (or School / Independent)" %>
          <%= f.text_field :company, autocomplete: "nope" %>
          <% if @entrant.errors[:company].any? %>
            <span class="form-field__error"><%= @entrant.errors[:company].first %></span>
          <% end %>
        </div>

        <div class="form-field <%= 'form-field--error' if @entrant.errors[:job_title].any? %>">
          <%= f.label :job_title, "Job Title (or Student / Researcher / etc.)" %>
          <%= f.text_field :job_title, autocomplete: "nope" %>
          <% if @entrant.errors[:job_title].any? %>
            <span class="form-field__error"><%= @entrant.errors[:job_title].first %></span>
          <% end %>
        </div>
      </div>

      <fieldset class="interest-areas">
        <legend>Interest Areas (optional)</legend>
        <div class="interest-areas__grid">
          <% Entrant::INTEREST_AREA_OPTIONS.each do |area| %>
            <div class="interest-areas__option">
              <%= check_box_tag "entrant[interest_areas][]", area, @entrant.interest_areas.include?(area), id: "interest_#{area.parameterize}" %>
              <%= label_tag "interest_#{area.parameterize}", area %>
            </div>
          <% end %>
        </div>
      </fieldset>
    </div>

    <div class="screen-form__footer">
      <div class="form-actions">
        <button type="button" class="btn btn--secondary" onclick="document.getElementById('rules-dialog').showModal()">Rules & Drawing Info</button>
        <%= f.submit "Submit Entry", class: "btn btn--primary" %>
      </div>
    </div>
  <% end %>
</div>

<dialog id="rules-dialog" class="rules-dialog">
  <div class="rules-dialog__content">
    <div class="rules-dialog__header">
      <span class="rules-dialog__title">Rules & Drawing Info</span>
      <button type="button" class="rules-dialog__close" onclick="document.getElementById('rules-dialog').close()" aria-label="Close">&times;</button>
    </div>

    <h3>Raffle Rules</h3>
    <ul>
      <li>One entry per person</li>
      <li>Entrants must provide accurate contact information</li>
      <li>Employees of CypherCon and CypherCon sponsors are not eligible</li>
      <li>Winner does not need to be present</li>
      <li>Prize will be shipped after the event if necessary</li>
      <li>Winner must respond within 2 business days of notification</li>
      <li>Fraudulent or duplicate entries may be disqualified</li>
      <li>Void where prohibited by law</li>
    </ul>

    <h3>Winner Selection</h3>
    <p>After CypherCon, Final Frontier Security will perform the drawing from the pool of eligible entries.</p>
    <p>The winner will be selected using the operating system's <strong>cryptographically secure random number generator</strong>, ensuring the selection is unbiased and unpredictable.</p>
  </div>
</dialog>
