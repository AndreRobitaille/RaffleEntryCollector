#!/usr/bin/env bash
# Idempotent kiosk setup script for Raffle Entry Collector
# Run as 'andre' user with sudo access on the Raspberry Pi
# Usage: bin/setup_kiosk

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

step() { echo -e "${GREEN}==>${NC} $1"; }
warn() { echo -e "${YELLOW}WARNING:${NC} $1"; }
fail() { echo -e "${RED}ERROR:${NC} $1"; exit 1; }

APP_SOURCE="$(cd "$(dirname "$0")/.." && pwd)"
APP_DEST="/opt/raffle"
RUBY_VERSION=$(cat "$APP_SOURCE/.ruby-version")

# Base PATH for the raffle system user (which has /usr/sbin/nologin as shell
# and therefore no login profile to set PATH). Scripts spawned by rbenv/ruby-build
# use #!/usr/bin/env bash, so /usr/bin and /bin must be present.
RAFFLE_PATH="$APP_DEST/.rbenv/bin:$APP_DEST/.rbenv/shims:/usr/local/bin:/usr/bin:/bin"

# --- Preflight checks -----------------------------------------------

if [ "$(whoami)" = "root" ]; then
    fail "Do not run as root. Run as 'andre' -- the script uses sudo where needed."
fi

if [ "$(whoami)" != "andre" ]; then
    fail "This script must be run as the 'andre' user."
fi

if ! sudo -n true 2>/dev/null; then
    fail "User 'andre' does not have passwordless sudo. Run 'sudo echo test' first."
fi

if [ ! -f "$APP_SOURCE/Gemfile" ]; then
    fail "Run this script from the RaffleEntryCollector directory (or its bin/ subdirectory)."
fi

# Move to a world-readable directory so sudo -u raffle inherits an accessible cwd.
# APP_SOURCE already captures the original path, so nothing else needs it.
cd /tmp

step "Starting kiosk setup from $APP_SOURCE"

# --- Step 1: Install system packages --------------------------------

step "Installing system packages..."
sudo apt-get update -qq
sudo apt-get install -y -qq \
    build-essential \
    libsqlite3-dev \
    libssl-dev \
    libreadline-dev \
    zlib1g-dev \
    libyaml-dev \
    libffi-dev \
    sqlite3 \
    curl \
    git \
    chromium \
    wayfire

# --- Step 2: Create raffle system user ------------------------------

if ! id -u raffle >/dev/null 2>&1; then
    step "Creating 'raffle' system user..."
    sudo useradd --system --create-home --home-dir "$APP_DEST" --shell /usr/sbin/nologin raffle
else
    step "'raffle' user already exists, skipping."
fi
# Ensure home directory exists even if user was created in a previous partial run
sudo mkdir -p "$APP_DEST"
sudo chown raffle:raffle "$APP_DEST"

# --- Step 3: Create kiosk user --------------------------------------

if ! id -u kiosk >/dev/null 2>&1; then
    step "Creating 'kiosk' user..."
    sudo useradd --create-home --shell /bin/bash kiosk
    # Lock password so kiosk user can't sudo or login with password
    sudo passwd -l kiosk
else
    step "'kiosk' user already exists, skipping."
fi
# Ensure home directory exists even if user was created in a previous partial run
sudo mkdir -p /home/kiosk
sudo chown kiosk:kiosk /home/kiosk

# --- Step 4: Lock root account --------------------------------------

step "Locking root account..."
sudo passwd -l root

# --- Step 5: Harden SSH ---------------------------------------------

step "Hardening SSH..."
if grep -q "^PermitRootLogin" /etc/ssh/sshd_config; then
    sudo sed -i 's/^PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config
else
    echo "PermitRootLogin no" | sudo tee -a /etc/ssh/sshd_config >/dev/null
fi
sudo systemctl reload sshd 2>/dev/null || sudo systemctl reload ssh 2>/dev/null || true

# --- Step 6: Harden VNC ---------------------------------------------

step "Restricting VNC to localhost..."
WAYVNC_DIR="/home/andre/.config/wayvnc"
WAYVNC_CONF="$WAYVNC_DIR/config"
if [ -d "$WAYVNC_DIR" ] || command -v wayvnc >/dev/null 2>&1; then
    mkdir -p "$WAYVNC_DIR"
    if [ -f "$WAYVNC_CONF" ]; then
        if grep -q "^address=" "$WAYVNC_CONF"; then
            sed -i 's/^address=.*/address=127.0.0.1/' "$WAYVNC_CONF"
        else
            echo "address=127.0.0.1" >> "$WAYVNC_CONF"
        fi
    else
        echo "address=127.0.0.1" > "$WAYVNC_CONF"
    fi
else
    warn "wayvnc not found, skipping VNC hardening."
fi

# --- Step 7: Install rbenv + Ruby for raffle user -------------------

if [ -d "$APP_DEST/.rbenv/.git" ]; then
    step "rbenv already installed, skipping."
else
    step "Installing rbenv for raffle user..."
    sudo rm -rf "$APP_DEST/.rbenv"
    sudo -u raffle /bin/bash -c "
        export PATH='$RAFFLE_PATH'
        git clone https://github.com/rbenv/rbenv.git '$APP_DEST/.rbenv'
    "
fi

if [ -d "$APP_DEST/.rbenv/plugins/ruby-build/.git" ]; then
    step "ruby-build already installed, skipping."
else
    step "Installing ruby-build plugin..."
    sudo rm -rf "$APP_DEST/.rbenv/plugins/ruby-build"
    sudo -u raffle /bin/bash -c "
        export PATH='$RAFFLE_PATH'
        mkdir -p '$APP_DEST/.rbenv/plugins'
        git clone https://github.com/rbenv/ruby-build.git '$APP_DEST/.rbenv/plugins/ruby-build'
    "
fi

RBENV="$APP_DEST/.rbenv/bin/rbenv"
if ! sudo -u raffle /bin/bash -c "export PATH='$RAFFLE_PATH'; '$RBENV' versions --bare 2>/dev/null | grep -qF '$RUBY_VERSION'"; then
    step "Installing Ruby $RUBY_VERSION (this will take a while on Pi)..."
    sudo -u raffle /bin/bash -c "
        export PATH='$RAFFLE_PATH'
        export MAKE_OPTS='-j 2'
        rbenv install '$RUBY_VERSION'
    "
    step "Setting Ruby $RUBY_VERSION as global default..."
    sudo -u raffle /bin/bash -c "
        export PATH='$RAFFLE_PATH'
        rbenv global '$RUBY_VERSION'
    "
else
    step "Ruby $RUBY_VERSION already installed, skipping."
fi

# --- Step 8: Deploy app ---------------------------------------------

step "Deploying app to $APP_DEST..."
sudo rsync -a --delete \
    --exclude='.git' \
    --exclude='tmp/' \
    --exclude='log/' \
    --exclude='db/*.sqlite3' \
    --exclude='storage/' \
    --exclude='node_modules/' \
    --exclude='.rbenv/' \
    --exclude='.env' \
    --exclude='config/master.key' \
    --exclude='config/credentials.yml.enc' \
    --exclude='.bundle/' \
    --exclude='vendor/bundle/' \
    "$APP_SOURCE/" "$APP_DEST/"

# Fix ownership after root rsync, then create writable directories
sudo chown -R raffle:raffle "$APP_DEST"
sudo -u raffle mkdir -p "$APP_DEST/tmp" "$APP_DEST/log" "$APP_DEST/db"

step "Installing gems..."
sudo -u raffle /bin/bash -c "
    export PATH='$RAFFLE_PATH'
    cd '$APP_DEST'
    bundle config set --local deployment true
    bundle config set --local without 'development test'
    bundle install
"

# --- Step 9: Generate .env file -------------------------------------

if [ ! -f "$APP_DEST/.env" ]; then
    step "Generating .env file with auto-generated SECRET_KEY_BASE..."
    SECRET=$(openssl rand -hex 64)
    sudo -u raffle bash -c "cat > '$APP_DEST/.env'" <<EOF
RAILS_ENV=production
SECRET_KEY_BASE=$SECRET
EOF
else
    step ".env already exists, skipping (won't overwrite your secrets)."
fi
# Always enforce correct permissions (in case a previous run failed between create and chmod)
sudo chmod 600 "$APP_DEST/.env"
sudo chown raffle:raffle "$APP_DEST/.env"

# --- Step 9b: Set admin password via Rails credentials ---------------

step "Checking admin password in Rails credentials..."
if [ ! -f "$APP_DEST/config/master.key" ]; then
    step "No master.key found -- setting up Rails credentials..."
    echo ""
    echo -e "${YELLOW}============================================================${NC}"
    echo -e "${YELLOW} Admin password setup${NC}"
    echo -e "${YELLOW}============================================================${NC}"
    echo ""
    echo "  The admin console at /admin requires a password."
    echo "  Without this, you CANNOT manage entries, draw raffle"
    echo "  winners, or export data."
    echo ""
    while true; do
        read -r -s -p "  Enter admin password: " ADMIN_PW
        echo ""
        if [ -z "$ADMIN_PW" ]; then
            echo -e "  ${RED}Password cannot be empty.${NC}"
            continue
        fi
        read -r -s -p "  Confirm admin password: " ADMIN_PW_CONFIRM
        echo ""
        if [ "$ADMIN_PW" != "$ADMIN_PW_CONFIRM" ]; then
            echo -e "  ${RED}Passwords do not match. Try again.${NC}"
            continue
        fi
        break
    done

    # Write password to a temp file (raffle-owned, 600 perms) so it never
    # appears in process arguments or shell history. Shred it when done.
    PW_TMPFILE=$(mktemp /tmp/raffle-pw.XXXXXX)
    chmod 600 "$PW_TMPFILE"
    printf '%s' "$ADMIN_PW" > "$PW_TMPFILE"
    sudo chown raffle:raffle "$PW_TMPFILE"
    unset ADMIN_PW ADMIN_PW_CONFIRM

    # Remove stale credentials.yml.enc (deployed by rsync from dev machine,
    # encrypted with a different master key) and generate a fresh key pair.
    sudo rm -f "$APP_DEST/config/credentials.yml.enc"
    openssl rand -hex 16 | sudo -u raffle tee "$APP_DEST/config/master.key" >/dev/null
    sudo chmod 600 "$APP_DEST/config/master.key"

    sudo -u raffle /bin/bash -c "
        export PATH='$RAFFLE_PATH'
        cd '$APP_DEST'
        RAILS_ENV=production bundle exec rails runner '
            pw = File.read(ARGV[0]).strip
            creds = ActiveSupport::EncryptedConfiguration.new(
                config_path: Rails.root.join(\"config/credentials.yml.enc\"),
                key_path: Rails.root.join(\"config/master.key\"),
                env_key: \"RAILS_MASTER_KEY\",
                raise_if_missing_key: true
            )
            creds.write({ \"admin_password\" => pw }.to_yaml)
        ' '$PW_TMPFILE'
    "

    # Securely delete the temp file
    shred -u "$PW_TMPFILE" 2>/dev/null || rm -f "$PW_TMPFILE"

    sudo chmod 600 "$APP_DEST/config/master.key" "$APP_DEST/config/credentials.yml.enc"
    sudo chown raffle:raffle "$APP_DEST/config/master.key" "$APP_DEST/config/credentials.yml.enc"

    echo -e "  ${GREEN}Admin password encrypted and saved.${NC}"
else
    step "master.key exists, credentials already configured."
fi

# --- Step 10: Setup database ----------------------------------------

step "Setting up production database..."
sudo -u raffle /bin/bash -c "
    export PATH='$RAFFLE_PATH'
    cd '$APP_DEST'
    RAILS_ENV=production bundle exec rails db:create 2>/dev/null || true
    RAILS_ENV=production bundle exec rails db:migrate
"

# --- Step 11: Precompile assets -------------------------------------

step "Precompiling assets..."
sudo -u raffle /bin/bash -c "
    export PATH='$RAFFLE_PATH'
    cd '$APP_DEST'
    RAILS_ENV=production bundle exec rails assets:precompile
"

# --- Step 12: Install systemd services ------------------------------

step "Installing systemd services..."
sudo cp "$APP_DEST/config/systemd/raffle-kiosk.service" /etc/systemd/system/
sudo cp "$APP_DEST/config/systemd/raffle-backup.service" /etc/systemd/system/
sudo cp "$APP_DEST/config/systemd/raffle-backup.timer" /etc/systemd/system/

sudo systemctl daemon-reload
sudo systemctl enable raffle-kiosk.service
sudo systemctl enable raffle-backup.timer

# --- Step 13: Configure auto-login for kiosk user -------------------

step "Configuring auto-login for kiosk user on tty1..."
sudo mkdir -p /etc/systemd/system/getty@tty1.service.d
cat <<'AUTOLOGIN' | sudo tee /etc/systemd/system/getty@tty1.service.d/autologin.conf >/dev/null
[Service]
ExecStart=
ExecStart=-/sbin/agetty --autologin kiosk --noclear %I $TERM
AUTOLOGIN

# --- Step 14: Install Wayfire config ---------------------------------

step "Installing Wayfire config and login profile for kiosk user..."
sudo -u kiosk mkdir -p /home/kiosk/.config
sudo cp "$APP_DEST/config/kiosk/wayfire.ini" /home/kiosk/.config/wayfire.ini
sudo chown kiosk:kiosk /home/kiosk/.config/wayfire.ini
sudo cp "$APP_DEST/config/kiosk/bash_profile" /home/kiosk/.bash_profile
sudo chown kiosk:kiosk /home/kiosk/.bash_profile

# --- Step 15: Install Chromium launcher ------------------------------

step "Installing Chromium kiosk launcher..."
sudo cp "$APP_DEST/config/kiosk/chromium-kiosk.sh" /home/kiosk/chromium-kiosk.sh
sudo chmod +x /home/kiosk/chromium-kiosk.sh
sudo chown kiosk:kiosk /home/kiosk/chromium-kiosk.sh

# --- Step 16: Install udev rule and mount helper --------------------

step "Installing udev rule for USB backup..."
sudo cp "$APP_DEST/config/kiosk/99-raffle-backup.rules" /etc/udev/rules.d/
sudo cp "$APP_DEST/config/kiosk/raffle-usb-mount" /usr/local/bin/raffle-usb-mount
sudo chmod 755 /usr/local/bin/raffle-usb-mount
sudo chown root:root /usr/local/bin/raffle-usb-mount
sudo udevadm control --reload-rules

# --- Done ------------------------------------------------------------

PI_IP=$(hostname -I 2>/dev/null | awk '{print $1}')
PI_IP=${PI_IP:-<pi-ip>}

echo ""
echo -e "${GREEN}============================================================${NC}"
echo -e "${GREEN} Kiosk setup complete!${NC}"
echo -e "${GREEN}============================================================${NC}"
echo ""
echo "BEFORE THE EVENT:"
echo "  1. Prepare a USB backup drive:"
echo "     - Format as FAT32, label it exactly: RAFFLE_BACKUP"
echo "     - Plug it in before the event starts"
echo "     - Backups run automatically every 5 minutes"
echo ""
echo "  2. Reboot the Pi to start the kiosk:"
echo "     sudo reboot"
echo ""
echo "WHAT HAPPENS ON BOOT:"
echo "  - Rails server starts automatically"
echo "  - Kiosk user auto-logins (no password needed)"
echo "  - Chromium opens fullscreen to the raffle entry form"
echo "  - Startup takes about 30-45 seconds"
echo ""
echo "ADMIN CONSOLE:"
echo "  - URL: http://127.0.0.1:3000/admin"
echo "  - Use the password you just set during setup"
echo "  - From the kiosk screen: plug in a keyboard, press Ctrl+L,"
echo "    type the URL above, and press Enter"
echo "  - From your laptop: ssh andre@$PI_IP"
echo ""
echo "  What you can do in the admin console:"
echo "    - View/search all entries"
echo "    - Exclude or reinstate entrants"
echo "    - Draw raffle winner + 2 alternates"
echo "    - Export entries or winners as CSV"
echo ""
echo "DRAWING WINNERS:"
echo "  1. Go to Admin > Raffle"
echo "  2. Click 'Draw Winner + 2 Alternates' (needs 3+ eligible entries)"
echo "  3. Click 'Announce' to display the winner on screen"
echo ""
echo "IF SOMETHING GOES WRONG:"
echo "  - Kiosk frozen?   Hard power-cycle the Pi (unplug, plug back in)"
echo "  - Chromium crash?  It restarts automatically"
echo "  - Rails crash?     systemd restarts it within 5 seconds"
echo "  - Need a shell?    Ctrl+Alt+F2 on the kiosk, or SSH from laptop:"
echo "                     ssh andre@$PI_IP"
echo "  - Check logs:      sudo journalctl -u raffle-kiosk.service -n 50"
echo "  - Restart Rails:   sudo systemctl restart raffle-kiosk.service"
echo ""
echo "CHANGING ADMIN PASSWORD LATER:"
echo "  ssh andre@$PI_IP"
echo "  sudo -u raffle /bin/bash -c \\"
echo "    \"cd $APP_DEST && export PATH='$RAFFLE_PATH' && \\"
echo "    RAILS_ENV=production EDITOR=nano bundle exec rails credentials:edit\""
echo "  # Set admin_password: <new-password>, save, then:"
echo "  sudo systemctl restart raffle-kiosk.service"
echo ""
